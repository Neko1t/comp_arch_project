# ==========================================
# 1. 内存轨迹文件 (极其巨大，绝对不能提交！)
# ==========================================
*.trace
traces/

# ==========================================
# 2. 实验结果与日志输出
# ==========================================
# 排除所有的测试结果文件夹，避免大量日志刷屏
results_ddr4/
results_hbm2/
results_*/

# ==========================================
# 3. 模拟器编译产物 (DRAMSim3 Build Artifacts)
# ==========================================
# 我们只托管 DRAMSim3 的源码，排除本地编译生成的二进制文件
DRAMSim3/build/
CMakeCache.txt
CMakeFiles/
Makefile
*.cmake

# ==========================================
# 4. Python 临时文件与缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 5. 自动生成的图表
# ==========================================
# 如果你想把每次运行脚本生成的对比图表同步到 GitHub 上，
# 请在下面这行前面加个 # 号把它注释掉。
*.png

# ==========================================
# 6. 系统、编辑器与环境临时文件
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
